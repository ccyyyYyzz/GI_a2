\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Fixed-dwell quality and elapsed-time speed}{4}{subsection.6.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {One global power control trades incident dose for elapsed-time speed and scene-dependent fixed-dwell quality.} (a)~Truth, safe-comparator, and ridge reconstructions for a median and a worst fixed-dwell scene, with radiometric PSNR on each crop. (b)~Per-scene fixed-dwell gain $\Delta Q$ at $\nu =2000$: the campaign median is $+1.87$~dB and 19 of 24 scenes are positive; negative cases remain visible. (c)~Quality versus elapsed optical time $T_{\mathrm  {opt}}$ for a median-speed scene and two boundary cases. (d)~Elapsed-time speedup $S_{\mathrm  {gate}}$ for all 24 scenes: median $19.13$ and family-stratified lower bound $18.33$, with 21 of 24 above one. The benefits use $37.1\times $ incident dose and $2.6\times $ detected counts; this is a power-for-time comparison, not an equal-photon-budget comparison.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:imaging-results}{{3}{5}{\textbf {One global power control trades incident dose for elapsed-time speed and scene-dependent fixed-dwell quality.} (a)~Truth, safe-comparator, and ridge reconstructions for a median and a worst fixed-dwell scene, with radiometric PSNR on each crop. (b)~Per-scene fixed-dwell gain $\Delta Q$ at $\nu =2000$: the campaign median is $+1.87$~dB and 19 of 24 scenes are positive; negative cases remain visible. (c)~Quality versus elapsed optical time $T_{\mathrm {opt}}$ for a median-speed scene and two boundary cases. (d)~Elapsed-time speedup $S_{\mathrm {gate}}$ for all 24 scenes: median $19.13$ and family-stratified lower bound $18.33$, with 21 of 24 above one. The benefits use $37.1\times $ incident dose and $2.6\times $ detected counts; this is a power-for-time comparison, not an equal-photon-budget comparison}{figure.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Benefit and resource cost at the terminal dwell. $\Delta Q$ compares ridge control with the matched $0.60$ fixed-dwell comparator; $S_{\mathrm  {gate}}$ compares it with the safe reference. Dose and detected counts are normalized to the $0.60$ comparator.}}{5}{table.1}\protected@file@percent }
\newlabel{tab:operating-results}{{1}{5}{Benefit and resource cost at the terminal dwell. $\Delta Q$ compares ridge control with the matched $0.60$ fixed-dwell comparator; $S_{\mathrm {gate}}$ compares it with the safe reference. Dose and detected counts are normalized to the $0.60$ comparator}{table.1}{}}
