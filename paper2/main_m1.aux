\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Numerical verification of the jitter cap.} (a)~Information-optimal load $\bar  {\rho }^{*}$ versus hold-time jitter $c_v$ at $\nu =2000$. Two independent Monte-Carlo runs and the preregistered matched-asymptotic prediction follow a pooled fitted slope $-0.658$, consistent with the theorem's $-2/3$ power law. Marker and line styles distinguish theorem, prediction, and simulation. (b)~Fraction of count information retained when a jittered detector is operated at the zero-jitter ridge $\bar  {\rho }\approx 22$. Retention falls below one-half by $c_v=0.05$ and to a few per cent by $c_v=0.2$, showing why the operating load must track the detector's own recovery-time variation.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:jitter-validation}{{2}{4}{\textbf {Numerical verification of the jitter cap.} (a)~Information-optimal load $\rhobar ^{*}$ versus hold-time jitter $c_v$ at $\nu =2000$. Two independent Monte-Carlo runs and the preregistered matched-asymptotic prediction follow a pooled fitted slope $-0.658$, consistent with the theorem's $-2/3$ power law. Marker and line styles distinguish theorem, prediction, and simulation. (b)~Fraction of count information retained when a jittered detector is operated at the zero-jitter ridge $\rhobar \approx 22$. Retention falls below one-half by $c_v=0.05$ and to a few per cent by $c_v=0.2$, showing why the operating load must track the detector's own recovery-time variation}{figure.2}{}}
