\@writefile{lot}{\contentsline {table}{\numberline {S4}{\ignorespaces Complete EXACT-TV versus RQL comparison on the frozen $8^2$/$16^2$ grid (864 paired reconstructions). Cells give the median radiometric-PSNR gap $\mathrm  {PSNR}(\text  {EXACT-TV})-\mathrm  {PSNR}(\text  {RQL})$ in dB per $(\text  {side},\bar  \rho ,\nu )$ (pair count in parentheses; three seeds $\times $ six scenes per cell). The median gap stays within $0.011$~dB in magnitude throughout the deployment zone ($\bar  \rho \le 1$) and reaches only $-0.05$~dB in the extreme-load corner ($16^2$, $\bar  \rho \ge 0.6$, $\nu =2000$). Over all pairs: 141 exactly identical, median $+0.00$~dB, maximum $|{\rm  gap}|=9.23$~dB, and only $9.0\%$ of pairs exceed $0.1$~dB in either direction -- consistent with the nonconvexity of the exact objective and with no systematic advantage to either arm.}}{6}{table.4}\protected@file@percent }
\newlabel{tab:s4_grid}{{S4}{6}{Complete EXACT-TV versus RQL comparison on the frozen $8^2$/$16^2$ grid (864 paired reconstructions). Cells give the median radiometric-PSNR gap $\mathrm {PSNR}(\text {EXACT-TV})-\mathrm {PSNR}(\text {RQL})$ in dB per $(\text {side},\bar \rho ,\nu )$ (pair count in parentheses; three seeds $\times $ six scenes per cell). The median gap stays within $0.011$~dB in magnitude throughout the deployment zone ($\bar \rho \le 1$) and reaches only $-0.05$~dB in the extreme-load corner ($16^2$, $\bar \rho \ge 0.6$, $\nu =2000$). Over all pairs: 141 exactly identical, median $+0.00$~dB, maximum $|{\rm gap}|=9.23$~dB, and only $9.0\%$ of pairs exceed $0.1$~dB in either direction -- consistent with the nonconvexity of the exact objective and with no systematic advantage to either arm}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S9}{Descriptive measurement-audit distributions on the RQL arm of the $64^2$ detail cohort ($5400$ audited cells; $\mathrm  {audit\_status}=\textsc  {ok}$ for all $5400/5400$). Per $(\bar  \rho ,\nu )$: the refit-bootstrap discrepancy-ratio $d_{\mathrm  {ratio}}$ quantiles and the count of leak-suspect cells (True in $30$ of $5400$ cells overall). \emph  {The audit is descriptive and is not a model-adequacy test:} all audit statistics are excluded from regularization selection, reconstruction, cell inclusion, and every confirmatory pass/fail decision. The reference distribution is conditional on a smoothed plug-in scene, so its tail ranks are not calibrated model-class $p$-values and can be anti-conservative when the true scene is rougher than the plug-in.}}{6}{table.9}\protected@file@percent }
\newlabel{tab:s8_audit}{{S9}{6}{Descriptive measurement-audit distributions on the RQL arm of the $64^2$ detail cohort ($5400$ audited cells; $\mathrm {audit\_status}=\textsc {ok}$ for all $5400/5400$). Per $(\bar \rho ,\nu )$: the refit-bootstrap discrepancy-ratio $d_{\mathrm {ratio}}$ quantiles and the count of leak-suspect cells (True in $30$ of $5400$ cells overall). \emph {The audit is descriptive and is not a model-adequacy test:} all audit statistics are excluded from regularization selection, reconstruction, cell inclusion, and every confirmatory pass/fail decision. The reference distribution is conditional on a smoothed plug-in scene, so its tail ranks are not calibrated model-class $p$-values and can be anti-conservative when the true scene is rougher than the plug-in}{table.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S5}{\ignorespaces No-gate occupancy-ladder per-image fixed-dwell high-flux gain (per-image seed-mean radiometric PSNR at $\bar  \rho =0.6$ minus $\bar  \rho =0.05$, both at $\nu =2000$, equal mean detector load and equal incident dose across occupancies). $k=16$ is the gate-carrying arm (values are the frozen $\Delta Q_{\mathrm  {budget}}$); $k=512/32/1$ are no-gate controls/robustness rungs. The profile is nonmonotone in sparsity: $k=32$ attains the largest median gain, combining most of the contrast benefit with half the conditioning burden of $k=16$.}}{8}{table.5}\protected@file@percent }
\newlabel{tab:s5_ladder}{{S5}{8}{No-gate occupancy-ladder per-image fixed-dwell high-flux gain (per-image seed-mean radiometric PSNR at $\bar \rho =0.6$ minus $\bar \rho =0.05$, both at $\nu =2000$, equal mean detector load and equal incident dose across occupancies). $k=16$ is the gate-carrying arm (values are the frozen $\Delta Q_{\mathrm {budget}}$); $k=512/32/1$ are no-gate controls/robustness rungs. The profile is nonmonotone in sparsity: $k=32$ attains the largest median gain, combining most of the contrast benefit with half the conditioning burden of $k=16$}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S6}{\ignorespaces Dynamic-scattering detail: RQL radiometric PSNR under multiplicative lognormal AR(1) scattering ($\mathrm  {CV}(\alpha )=0.20$, applied before dead time) on the $k=16$ geometry over the six frozen mechanism representatives. Entries are mean $\pm $ sample sd (dB) over the six scenes $\times $ three seeds; the gain column is the fast-minus-safe difference of means. The high-flux gain persists and grows with dwell.}}{8}{table.6}\protected@file@percent }
\newlabel{tab:s6_scattering}{{S6}{8}{Dynamic-scattering detail: RQL radiometric PSNR under multiplicative lognormal AR(1) scattering ($\mathrm {CV}(\alpha )=0.20$, applied before dead time) on the $k=16$ geometry over the six frozen mechanism representatives. Entries are mean $\pm $ sample sd (dB) over the six scenes $\times $ three seeds; the gain column is the fast-minus-safe difference of means. The high-flux gain persists and grows with dwell}{table.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S7}{\ignorespaces Undersampling sensitivity (S2B): median RQL radiometric PSNR (dB) for dense Bernoulli$(1/2)$ illumination at two sampling budgets $M\in \{1024,2048\}$, over 12 scenes $\times $ 3 seeds per cell. Source: \texttt  {round63\_s2\_s2b/pilot\_rows.csv} (commit 7b9d20e).}}{8}{table.7}\protected@file@percent }
\newlabel{tab:s7_s2b}{{S7}{8}{Undersampling sensitivity (S2B): median RQL radiometric PSNR (dB) for dense Bernoulli$(1/2)$ illumination at two sampling budgets $M\in \{1024,2048\}$, over 12 scenes $\times $ 3 seeds per cell. Source: \texttt {round63\_s2\_s2b/pilot\_rows.csv} (commit 7b9d20e)}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {S8}{\ignorespaces Ensemble sensitivity (S2C): median RQL radiometric PSNR (dB) for complementary Hadamard-type pairs (\texttt  {hadpair}) and gamma-modulated patterns (\texttt  {gam4}) at $M=2048$, over 12 scenes $\times $ 3 seeds per cell. Source: \texttt  {round63\_s2\_s2c/pilot\_rows.csv} (commit UNTRACKED).}}{9}{table.8}\protected@file@percent }
\newlabel{tab:s7_s2c}{{S8}{9}{Ensemble sensitivity (S2C): median RQL radiometric PSNR (dB) for complementary Hadamard-type pairs (\texttt {hadpair}) and gamma-modulated patterns (\texttt {gam4}) at $M=2048$, over 12 scenes $\times $ 3 seeds per cell. Source: \texttt {round63\_s2\_s2c/pilot\_rows.csv} (commit UNTRACKED)}{table.8}{}}
