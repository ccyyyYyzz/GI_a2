\@writefile{lot}{\contentsline {table}{\numberline {S1}{Full NATURAL-30 cohort (secondary, no gate): per-image acquisition-speed endpoint on the RQL arm, reproduced verbatim from the frozen analyzer output. \textsc  {sru} = \textsc  {safe\_range\_uninformative} ($S_{\mathrm  {gate}}=1$ by the frozen censoring taxonomy). $T_{\mathrm  {safe}},T_{\mathrm  {fast}}$ are $Q_{90}$ crossing times (s); $R_j$ the safe-arm quality span; $\Delta Q_{\mathrm  {budget}}$ the fixed-dwell radiometric-PSNR gain at $\nu =2000$. The two synthetic stress scenes bracket the cohort: \texttt  {low\_contrast} ($\Delta Q=-1.78$~dB, the only strongly negative rung) and \texttt  {fine\_lines} ($\Delta Q=+0.07$~dB). Cohort median $S_{\mathrm  {gate}}=5.70$; median $\Delta Q=+1.44$~dB, positive in $29/30$ scenes; $12/30$ scenes safe-range-uninformative.}}{2}{table.1}\protected@file@percent }
\newlabel{tab:s2_natural}{{S1}{2}{Full NATURAL-30 cohort (secondary, no gate): per-image acquisition-speed endpoint on the RQL arm, reproduced verbatim from the frozen analyzer output. \textsc {sru} = \textsc {safe\_range\_uninformative} ($S_{\mathrm {gate}}=1$ by the frozen censoring taxonomy). $T_{\mathrm {safe}},T_{\mathrm {fast}}$ are $Q_{90}$ crossing times (s); $R_j$ the safe-arm quality span; $\Delta Q_{\mathrm {budget}}$ the fixed-dwell radiometric-PSNR gain at $\nu =2000$. The two synthetic stress scenes bracket the cohort: \texttt {low\_contrast} ($\Delta Q=-1.78$~dB, the only strongly negative rung) and \texttt {fine\_lines} ($\Delta Q=+0.07$~dB). Cohort median $S_{\mathrm {gate}}=5.70$; median $\Delta Q=+1.44$~dB, positive in $29/30$ scenes; $12/30$ scenes safe-range-uninformative}{table.1}{}}
